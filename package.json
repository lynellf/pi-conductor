{
  "name": "pi-conductor",
  "version": "0.8.1",
  "description": "Multi-role LLM orchestration via a guarded, observable handoff state machine — installs as a pi extension exposing `/conduct`.",
  "license": "MIT",
  "author": "Ezell <lynellf@gmail.com>",
  "repository": {
    "type": "git",
    "url": "github:lynellf/pi-conductor"
  },
  "homepage": "https://github.com/lynellf/pi-conductor#readme",
  "bugs": {
    "url": "https://github.com/lynellf/pi-conductor/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "dist",
    "extensions",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "conduct": "./dist/bin/conduct.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bin/conduct": "./dist/bin/conduct.js"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "orchestration",
    "llm-workflow",
    "state-machine",
    "fsm",
    "multi-agent",
    "agent-workflow",
    "claude"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "audit": "pnpm audit --prod",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm typecheck && pnpm build && pnpm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@earendil-works/pi-tui": "^0.79.1",
    "@types/node": "^22.10.0",
    "lefthook": "^2.1.9",
    "typebox": "^1.1.38",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "diff": "^8.0.2",
    "yaml": "^2.6.0"
  }
}
